<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Milkah Supply Line</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<!-- HEADER -->
<header class="bg-green-600 text-white p-4 text-center font-bold text-lg">
  Milkah Supply Line
</header>

<!-- PRODUCT GRID -->
<div id="productGrid" class="grid grid-cols-2 gap-3 p-3"></div>

<!-- CART BUTTON -->
<button id="cartBtn" class="fixed bottom-5 right-5 bg-green-600 text-white p-4 rounded-full shadow-lg">
  🛒 <span id="cartCount">0</span>
</button>

<!-- CART MODAL -->
<div id="cartModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-end">
  <div class="bg-white w-full rounded-t-xl p-4 max-h-[80vh] overflow-y-auto">
    
    <h2 class="text-lg font-bold mb-3">Your Cart</h2>

    <div id="cartItems"></div>

    <div class="mt-3 font-bold">
      Total: KSh <span id="totalPrice">0</span>
    </div>

    <button onclick="checkoutWhatsApp()" 
      class="w-full bg-green-600 text-white py-3 mt-4 rounded-lg">
      Checkout via WhatsApp
    </button>

    <button onclick="toggleCart()" 
      class="w-full mt-2 text-gray-500">
      Close
    </button>
  </div>
</div>

<script>
// ================= PRODUCT DATA =================
// 👉 EASY TO SCALE: Just add more products here
const products = [
  { id: 1, name: "Brookside", price: 672 },
  { id: 2, name: "Lotus", price: 1795 },
  { id: 3, name: "Ajab", price: 1920 },
  { id: 4, name: "Classic", price: 1410 },
  { id: 5, name: "Raha 2kg", price: 2244 },
  { id: 6, name: "Raha 1kg", price: 2233 },
  { id: 7, name: "Postman", price: 4850 }
];

// ================= STATE =================
let cart = {};

// ================= FORMAT PRICE =================
function formatPrice(num) {
  return num.toLocaleString("en-KE");
}

// ================= RENDER PRODUCTS =================
function renderProducts() {
  const grid = document.getElementById("productGrid");

  products.forEach(product => {
    grid.innerHTML += `
      <div class="bg-white p-3 rounded-lg shadow">
        <img src="https://via.placeholder.com/150" class="w-full rounded mb-2">
        <h3 class="font-semibold text-sm">${product.name}</h3>
        <p class="text-green-600 font-bold">KSh ${formatPrice(product.price)}</p>
        <button onclick="addToCart(${product.id})"
          class="mt-2 w-full bg-green-500 text-white py-2 rounded text-sm">
          Add to Cart
        </button>
      </div>
    `;
  });
}

// ================= ADD TO CART =================
function addToCart(id) {
  if (cart[id]) {
    cart[id]++;
  } else {
    cart[id] = 1;
  }
  updateCartCount();
}

// ================= CART COUNT =================
function updateCartCount() {
  const count = Object.values(cart).reduce((a, b) => a + b, 0);
  document.getElementById("cartCount").innerText = count;
}

// ================= TOGGLE CART =================
function toggleCart() {
  const modal = document.getElementById("cartModal");
  modal.classList.toggle("hidden");
  renderCart();
}

// ================= RENDER CART =================
function renderCart() {
  const container = document.getElementById("cartItems");
  const totalEl = document.getElementById("totalPrice");

  container.innerHTML = "";
  let total = 0;

  for (let id in cart) {
    const product = products.find(p => p.id == id);
    const qty = cart[id];
    const subtotal = product.price * qty;
    total += subtotal;

    container.innerHTML += `
      <div class="flex justify-between py-2 border-b text-sm">
        <div>${product.name} x${qty}</div>
        <div>KSh ${formatPrice(subtotal)}</div>
      </div>
    `;
  }

  totalEl.innerText = formatPrice(total);
}

// ================= WHATSAPP CHECKOUT =================
function checkoutWhatsApp() {

  let message = "Hello, I would like to place an order:%0A%0A";

  let total = 0;

  for (let id in cart) {
    const product = products.find(p => p.id == id);
    const qty = cart[id];
    const subtotal = product.price * qty;
    total += subtotal;

    message += `${product.name} x${qty} - KSh ${formatPrice(subtotal)}%0A`;
  }

  message += `%0ATotal: KSh ${formatPrice(total)}%0A`;

  // 👉 REPLACE WITH REAL NUMBER
  const phone = "254712345678";

  const url = `https://wa.me/${phone}?text=${message}`;

  window.location.href = url;
}

// ================= INIT =================
renderProducts();
document.getElementById("cartBtn").addEventListener("click", toggleCart);

</script>

</body>
</html>
